{
    "name": "luremo/craft-data-export-builder",
    "description": "Reusable CSV, JSON, and XLSX exports for Craft CMS teams that need reporting, migrations, and operational handoffs without custom scripts.",
    "type": "craft-plugin",
    "license": "proprietary",
    "version": "1.0.0",
    "keywords": [
        "craftcms",
        "craft-cms",
        "plugin",
        "exports",
        "csv",
        "json"
    ],
    "homepage": "https://github.com/LuukRM2000/Data-export-builder",
    "support": {
        "issues": "https://github.com/LuukRM2000/Data-export-builder/issues",
        "source": "https://github.com/LuukRM2000/Data-export-builder"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Luremo\\DataExportBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Luremo\\DataExportBuilder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always"
    },
    "extra": {
        "name": "Data Export Builder",
        "handle": "data-export-builder",
        "class": "Luremo\\DataExportBuilder\\Plugin",
        "description": "Build reusable CSV, JSON, and XLSX exports for Craft CMS without custom templates or one-off scripts.",
        "developer": "Luremo",
        "developerUrl": "https://github.com/LuukRM2000",
        "documentationUrl": "https://github.com/LuukRM2000/Data-export-builder#readme",
        "changelogUrl": "https://github.com/LuukRM2000/Data-export-builder/blob/main/CHANGELOG.md",
        "pluginStoreUrl": "https://plugins.craftcms.com/data-export-builder"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true
        }
    }
}
