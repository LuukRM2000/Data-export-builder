{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set isNew = not template.id %}
{% set title = isNew ? 'New Export Template' : template.name %}
{% set selectedFields = template.getFieldsSorted() %}
{% set queueThreshold = template.settings.queueThreshold ?? 1000 %}
{% set sectionUid = template.filters.sectionUid ?? '' %}
{% set siteUid = template.filters.siteUid ?? '' %}
{% set formId = template.filters.formId ?? '' %}
{% set dateFrom = template.filters.dateFrom ?? '' %}
{% set dateTo = template.filters.dateTo ?? '' %}

{% block actionButton %}
    <a class="btn" href="{{ cpUrl('data-export-builder/exports') }}">Back to Exports</a>
{% endblock %}

{% block content %}
    <div class="deb-page">
        <div class="deb-main">
            <form method="post" accept-charset="UTF-8">
                {{ csrfInput() }}
                {{ actionInput('data-export-builder/templates/save') }}
                {{ hiddenInput('templateId', template.id) }}

                {{ forms.textField({
                    first: true,
                    label: 'Name',
                    instructions: 'A client-friendly label for the reusable export template.',
                    id: 'name',
                    name: 'name',
                    required: true,
                    value: template.name,
                    errors: template.getErrors('name')
                }) }}

                {{ forms.textField({
                    label: 'Handle',
                    instructions: 'Used for file naming and future automation hooks.',
                    id: 'handle',
                    name: 'handle',
                    required: true,
                    value: template.handle,
                    errors: template.getErrors('handle')
                }) }}

                <div class="deb-card">
                    <div class="deb-card__header">
                        <h2>Template Setup</h2>
                        <p>Choose what this export targets and how it should run.</p>
                    </div>

                    <div class="deb-form-grid">
                        {{ forms.selectField({
                            label: 'Element Type',
                            id: 'elementType',
                            name: 'elementType',
                            options: elementTypeOptions,
                            value: template.elementType,
                            instructions: 'Entries, users, categories, assets, and Commerce orders when available.'
                        }) }}

                        {{ forms.selectField({
                            label: 'Output Format',
                            id: 'format',
                            name: 'format',
                            options: [
                                { label: 'CSV', value: 'csv' },
                                { label: 'JSON', value: 'json' }
                            ],
                            value: template.format
                        }) }}

                        <div data-section-filter-row>
                            {{ forms.selectField({
                                label: 'Section Filter',
                                id: 'sectionUid',
                                name: 'filters[sectionUid]',
                                options: fieldPayload.sections,
                                value: sectionUid,
                                instructions: 'Optional. Only applies to entry exports.'
                            }) }}
                        </div>

                        <div data-site-filter-row>
                            {{ forms.selectField({
                                label: 'Site Filter',
                                id: 'siteUid',
                                name: 'filters[siteUid]',
                                options: fieldPayload.sites,
                                value: siteUid,
                                instructions: 'Optional. Export from one site or all sites.'
                            }) }}
                        </div>

                        <div data-form-filter-row>
                            {{ forms.selectField({
                                label: 'Wheel Form',
                                id: 'formId',
                                name: 'filters[formId]',
                                options: fieldPayload.forms ?? [],
                                value: formId,
                                instructions: 'Required for Wheel Form submission exports.'
                            }) }}
                        </div>

                        <div class="field">
                            <div class="heading">
                                <label id="dateFrom-label" for="dateFrom">Created From</label>
                            </div>
                            <div class="instructions">
                                <p>Optional. Filter by creation date.</p>
                            </div>
                            <div class="input">
                                <input
                                    class="text fullwidth"
                                    type="date"
                                    id="dateFrom"
                                    name="filters[dateFrom]"
                                    value="{{ dateFrom }}"
                                >
                            </div>
                        </div>

                        <div class="field">
                            <div class="heading">
                                <label id="dateTo-label" for="dateTo">Created To</label>
                            </div>
                            <div class="instructions">
                                <p>Optional. Leave blank to include all dates.</p>
                            </div>
                            <div class="input">
                                <input
                                    class="text fullwidth"
                                    type="date"
                                    id="dateTo"
                                    name="filters[dateTo]"
                                    value="{{ dateTo }}"
                                >
                            </div>
                        </div>

                        {{ forms.textField({
                            label: 'Queue Threshold',
                            id: 'queueThreshold',
                            name: 'settings[queueThreshold]',
                            value: queueThreshold,
                            type: 'number',
                            instructions: 'Exports above this row count are pushed to the Craft queue.'
                        }) }}
                    </div>
                </div>

                <div class="buttons">
                    <button type="submit" class="btn submit">Save Template</button>
                </div>

                {% include 'data-export-builder/_cp/exports/_includes/field-picker' with {
                    fieldPayload: fieldPayload,
                    selectedFields: selectedFields
                } %}

                {% if template.getErrors('fields') %}
                    <p class="error">{{ template.getFirstError('fields') }}</p>
                {% endif %}

            </form>
        </div>

        <aside class="deb-sidebar">
            <div class="deb-card">
                <div class="deb-card__header">
                    <h2>Run Export</h2>
                    <p>Save first, then run on demand. Larger datasets queue automatically.</p>
                </div>

                {% if template.id %}
                    <form method="post" action="{{ cpUrl('data-export-builder/exports/' ~ template.id ~ '/run') }}">
                        {{ csrfInput() }}
                        <button type="submit" class="btn submit fullwidth">Run Export</button>
                    </form>
                {% else %}
                    <p class="light">Save this template to unlock export runs and download history.</p>
                {% endif %}
            </div>

            {% if template.id %}
                <div class="deb-card">
                    <div class="deb-card__header">
                        <h2>Template Actions</h2>
                        <p>Useful lifecycle actions for agency handoff workflows.</p>
                    </div>

                    <div class="deb-stack">
                        <form method="post" accept-charset="UTF-8">
                            {{ csrfInput() }}
                            {{ actionInput('data-export-builder/templates/duplicate') }}
                            {{ hiddenInput('templateId', template.id) }}
                            <button type="submit" class="btn fullwidth">Duplicate Template</button>
                        </form>

                        <form method="post" accept-charset="UTF-8" onsubmit="return confirm('Delete this export template and its run history?');">
                            {{ csrfInput() }}
                            {{ actionInput('data-export-builder/templates/delete') }}
                            {{ hiddenInput('templateId', template.id) }}
                            <button type="submit" class="btn fullwidth danger">Delete Template</button>
                        </form>
                    </div>
                </div>
            {% endif %}

            {% include 'data-export-builder/_cp/exports/_includes/run-history' with {
                template: template,
                runs: runs
            } %}
        </aside>
    </div>
{% endblock %}
