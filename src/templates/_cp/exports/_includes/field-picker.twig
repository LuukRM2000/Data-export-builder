<div class="deb-card">
    <div class="deb-card__header">
        <h2>Fields</h2>
        <p>Build the exported column set without custom Twig templates or one-off scripts.</p>
    </div>

    <div
        class="deb-field-picker"
        data-deb-field-picker
        data-fields-url="{{ cpUrl('data-export-builder/exports/fields') }}"
        data-initial-payload="{{ fieldPayload|json_encode|e('html_attr') }}"
        data-element-select="#elementType"
        data-section-filter-target="[data-section-filter-row]"
        data-site-filter-target="[data-site-filter-row]"
    >
        <div class="deb-field-picker__panel">
            <label class="deb-search-label" for="deb-field-search">Available Fields</label>
            <input id="deb-field-search" class="text fullwidth" type="search" placeholder="Search fields, relations, Matrix paths..." data-field-search>
            <div class="deb-available-fields" data-available-fields></div>
        </div>

        <div class="deb-field-picker__panel">
            <div class="deb-selected-header">
                <label>Selected Columns</label>
                <span class="light">Rename and reorder before saving.</span>
            </div>

            <div class="deb-selected-list" data-selected-fields>
                {% for field in selectedFields %}
                    <div class="deb-selected-row" data-selected-row data-field-path="{{ field.fieldPath }}">
                        <div class="deb-selected-row__main">
                            <input type="hidden" data-name="fieldPath" name="fields[{{ loop.index0 }}][fieldPath]" value="{{ field.fieldPath }}">
                            <input type="hidden" data-name="sortOrder" name="fields[{{ loop.index0 }}][sortOrder]" value="{{ field.sortOrder }}">
                            <div class="deb-selected-path">{{ field.fieldPath }}</div>
                            <input class="text fullwidth" type="text" data-name="columnLabel" name="fields[{{ loop.index0 }}][columnLabel]" value="{{ field.columnLabel }}" placeholder="Column label">
                        </div>

                        <div class="deb-selected-row__actions">
                            <button type="button" class="btn small" data-move-up aria-label="Move up">Up</button>
                            <button type="button" class="btn small" data-move-down aria-label="Move down">Down</button>
                            <button type="button" class="btn small" data-remove-field aria-label="Remove field">Remove</button>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <p class="light{% if selectedFields %} hidden{% endif %}" data-selected-empty>No fields selected yet. Add fields from the left to define the export.</p>
        </div>
    </div>
</div>
